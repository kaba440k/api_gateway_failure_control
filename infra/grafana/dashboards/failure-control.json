{
  "uid": "failure-control",
  "title": "API Gateway Failure Control",
  "tags": ["diploma", "envoy", "fastapi"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "HTTP request rate by application",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (app, route, status_code) (rate(app_http_requests_total[1m]))",
          "legendFormat": "{{app}} {{route}} {{status_code}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Request latency p95, seconds",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, app, route) (rate(app_http_request_duration_seconds_bucket[1m])))",
          "legendFormat": "{{app}} {{route}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Circuit breaker events in selected range",
      "gridPos": { "x": 0, "y": 8, "w": 8, "h": 6 },
      "fieldConfig": {
        "defaults": {
          "decimals": 0,
          "unit": "none"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "round(sum by (event, state) (increase(control_circuit_breaker_events_total[$__range])))",
          "legendFormat": "{{event}} {{state}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Retry results in selected range",
      "gridPos": { "x": 8, "y": 8, "w": 8, "h": 6 },
      "fieldConfig": {
        "defaults": {
          "decimals": 0,
          "unit": "none"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "round(sum by (result) (increase(control_retry_events_total[$__range])))",
          "legendFormat": "{{result}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Envoy upstream 5xx rate",
      "gridPos": { "x": 16, "y": 8, "w": 8, "h": 6 },
      "targets": [
        {
          "expr": "sum by (envoy_cluster_name) (rate(envoy_cluster_upstream_rq_xx{envoy_response_code_class=\"5\"}[1m]))",
          "legendFormat": "{{envoy_cluster_name}}",
          "refId": "A"
        }
      ]
    }
  ]
}
