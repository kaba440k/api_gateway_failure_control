{
  "uid": "failure-control",
  "title": "API Gateway Failure Control",
  "tags": ["diploma", "envoy", "fastapi"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "HTTP-запросы по приложениям",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (app, path, status) (rate(app_http_requests_total[1m]))",
          "legendFormat": "{{app}} {{path}} {{status}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Задержка запросов p95, секунды",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, app, path) (rate(app_http_request_duration_seconds_bucket[1m])))",
          "legendFormat": "{{app}} {{path}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "События Circuit Breaker за период",
      "gridPos": { "x": 0, "y": 8, "w": 8, "h": 6 },
      "fieldConfig": {
        "defaults": {
          "decimals": 0,
          "unit": "none"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "round(sum by (event, state) (increase(control_circuit_breaker_events_total[$__range])))",
          "legendFormat": "{{event}} {{state}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Результаты Retry за период",
      "gridPos": { "x": 8, "y": 8, "w": 8, "h": 6 },
      "fieldConfig": {
        "defaults": {
          "decimals": 0,
          "unit": "none"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "round(sum by (result) (increase(control_retry_events_total[$__range])))",
          "legendFormat": "{{result}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Ошибки 5xx от сервисов через Envoy",
      "gridPos": { "x": 16, "y": 8, "w": 8, "h": 6 },
      "targets": [
        {
          "expr": "sum by (envoy_cluster_name) (rate(envoy_cluster_upstream_rq_xx{envoy_response_code_class=\"5\"}[1m]))",
          "legendFormat": "{{envoy_cluster_name}}",
          "refId": "A"
        }
      ]
    }
  ]
}
