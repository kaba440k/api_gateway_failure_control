COMPOSE_PROJECT_NAME=api-gateway-failure-control

POSTGRES_DB=diplom
POSTGRES_USER=diplom
POSTGRES_PASSWORD=change_me
POSTGRES_PORT=5432

REDIS_PORT=6379

ENVOY_GATEWAY_PORT=10000
ENVOY_ADMIN_PORT=9901
CONTROL_API_PORT=8000
FRONTEND_PORT=8080
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change_me

CONTROL_API_APP_NAME=control-api

DATABASE_URL=postgresql+asyncpg://diplom:change_me@localhost:5432/diplom
DATABASE_URL_DOCKER=postgresql+asyncpg://diplom:change_me@postgres:5432/diplom

REDIS_URL=redis://localhost:6379/0
REDIS_URL_DOCKER=redis://redis:6379/0

UPSTREAM_UNSTABLE_URL=http://localhost:8003/unstable
UPSTREAM_UNSTABLE_URL_DOCKER=http://unstable-service:8000/unstable

GATEWAY_URL=http://localhost:10000
PROMETHEUS_URL=http://localhost:9090
GRAFANA_URL=http://localhost:3000

CIRCUIT_FAILURE_THRESHOLD=3
CIRCUIT_OPEN_TIMEOUT_SECONDS=10
RETRY_ATTEMPTS=3
RETRY_INITIAL_DELAY_SECONDS=0.2
RETRY_MAX_DELAY_SECONDS=1.5
